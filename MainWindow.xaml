<Window x:Class="CodexChannelLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Codex 多开器"
        Width="1180"
        Height="700"
        MinWidth="1040"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        SourceInitialized="Window_SourceInitialized">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="58"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="18"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <LinearGradientBrush x:Key="CardSurfaceBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D91A1F2B" Offset="0" />
            <GradientStop Color="#BE111621" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="WarningBrush" Color="#F3C777" />

        <Style x:Key="EyebrowText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7E89A1" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#68738B" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8DDEA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,5,0,0" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Background" Value="#121722" />
            <Setter Property="BorderBrush" Value="#2A3244" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            BorderBrush="#3A4257"
            BorderThickness="1"
            Background="#0B0E16">
        <Grid x:Name="RootContent" ClipToBounds="True" Opacity="0">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F40B0F18" Offset="0" />
                    <GradientStop Color="#F20D1019" Offset="0.58" />
                    <GradientStop Color="#F412101B" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>

            <Canvas x:Name="LavaLayer"
                    Margin="-120"
                    IsHitTestVisible="False"
                    ClipToBounds="False">
                <Ellipse Width="600"
                         Height="470"
                         Canvas.Left="-90"
                         Canvas.Top="-120"
                         Opacity="0.56"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect>
                        <BlurEffect Radius="92" RenderingBias="Performance" />
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.42,0.42" GradientOrigin="0.38,0.35" RadiusX="0.62" RadiusY="0.62">
                            <GradientStop Color="#BD8D65FF" Offset="0" />
                            <GradientStop Color="#6B6749DE" Offset="0.48" />
                            <GradientStop Color="#006749DE" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="LavaVioletScale" ScaleX="1" ScaleY="1" />
                            <RotateTransform x:Name="LavaVioletRotate" Angle="-8" />
                            <TranslateTransform x:Name="LavaVioletShift" />
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="660"
                         Height="520"
                         Canvas.Left="700"
                         Canvas.Top="-40"
                         Opacity="0.48"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect>
                        <BlurEffect Radius="105" RenderingBias="Performance" />
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.45,0.45" GradientOrigin="0.56,0.35" RadiusX="0.64" RadiusY="0.64">
                            <GradientStop Color="#A846C9C1" Offset="0" />
                            <GradientStop Color="#574087A9" Offset="0.5" />
                            <GradientStop Color="#004087A9" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="LavaTealScale" ScaleX="1" ScaleY="1" />
                            <RotateTransform x:Name="LavaTealRotate" Angle="10" />
                            <TranslateTransform x:Name="LavaTealShift" />
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="570"
                         Height="430"
                         Canvas.Left="360"
                         Canvas.Top="380"
                         Opacity="0.44"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect>
                        <BlurEffect Radius="98" RenderingBias="Performance" />
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.48,0.5" GradientOrigin="0.36,0.58" RadiusX="0.65" RadiusY="0.65">
                            <GradientStop Color="#B8E46F78" Offset="0" />
                            <GradientStop Color="#656C3C84" Offset="0.52" />
                            <GradientStop Color="#006C3C84" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="LavaRoseScale" ScaleX="1" ScaleY="1" />
                            <RotateTransform x:Name="LavaRoseRotate" Angle="-14" />
                            <TranslateTransform x:Name="LavaRoseShift" />
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse Width="520"
                         Height="420"
                         Canvas.Left="-150"
                         Canvas.Top="470"
                         Opacity="0.42"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Effect>
                        <BlurEffect Radius="96" RenderingBias="Performance" />
                    </Ellipse.Effect>
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.48,0.46" GradientOrigin="0.42,0.58" RadiusX="0.66" RadiusY="0.66">
                            <GradientStop Color="#A94E89E8" Offset="0" />
                            <GradientStop Color="#55455BB4" Offset="0.53" />
                            <GradientStop Color="#00455BB4" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="LavaBlueScale" ScaleX="1" ScaleY="1" />
                            <RotateTransform x:Name="LavaBlueRotate" Angle="6" />
                            <TranslateTransform x:Name="LavaBlueShift" />
                        </TransformGroup>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Canvas>

            <Border IsHitTestVisible="False" Background="#31070A11" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#202637" BorderThickness="0,0,0,1">
                    <Grid Margin="20,0,14,0" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="28" Height="28" CornerRadius="9" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C9BFFF" Offset="0" />
                                    <GradientStop Color="#6655C9" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="✦"
                                       FontSize="14"
                                       Foreground="#11131B"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="11,0,0,0">
                            <TextBlock Text="CODEX 多开器"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#C9CFDC" />
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Style="{StaticResource WindowButton}" Content="—" Click="MinimizeButton_Click" />
                            <Button Style="{StaticResource WindowButton}" Content="×" Click="CloseButton_Click" Margin="5,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="46,24,46,30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Margin="0,0,0,18"
                            Padding="15,11"
                            CornerRadius="15"
                            Background="#A9121722"
                            BorderBrush="#30384B"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="27" Height="27" CornerRadius="9" Background="#1B2B2A">
                                <Path Data="M 7,13 L 11,17 L 20,8"
                                      Stroke="#6DDEB4"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Width="14"
                                      Height="11"
                                      Stretch="Fill" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       x:Name="IsolationStateText"
                                       Text="正在核对隔离边界"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#C6CCDA"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="APP"
                                       Style="{StaticResource MetricCaption}"
                                       VerticalAlignment="Center"
                                       Margin="20,0,10,0" />
                            <TextBlock Grid.Column="3"
                                       x:Name="PackageVersionText"
                                       Text="detecting…"
                                       FontFamily="Cascadia Mono, Consolas"
                                       FontSize="11"
                                       Foreground="#AEB6C8"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1"
                                  Margin="-9,-9,-9,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False">
                        <ItemsControl x:Name="ProfileCards">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="9" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="20"
                                            Background="{StaticResource CardSurfaceBrush}"
                                            BorderBrush="{Binding CardBorderBrush}"
                                            BorderThickness="1"
                                            Padding="22,20"
                                            Tag="{Binding IdentityKey}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="7" Opacity="0.20" />
                                        </Border.Effect>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="44"
                                                            Height="44"
                                                            CornerRadius="14"
                                                            Background="{Binding AccentSoftBrush}"
                                                            BorderBrush="{Binding CardBorderBrush}"
                                                            BorderThickness="1">
                                                        <TextBlock Text="{Binding IconGlyph}"
                                                                   Foreground="{Binding AccentBrush}"
                                                                   FontFamily="{StaticResource DisplayFont}"
                                                                   FontSize="16"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="13,1,0,0">
                                                        <TextBlock Text="{Binding Eyebrow}"
                                                                   Style="{StaticResource EyebrowText}"
                                                                   Foreground="{Binding AccentBrush}" />
                                                        <Grid Margin="0,4,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Title}"
                                                                       ToolTip="{Binding Title}"
                                                                       FontFamily="{StaticResource DisplayFont}"
                                                                       FontSize="19"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <Border Grid.Column="1"
                                                                    CornerRadius="8"
                                                                    Padding="7,2"
                                                                    Background="{Binding AccentSoftBrush}"
                                                                    Margin="9,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding IsPersonal, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="默认主空间"
                                                                           FontSize="9.5"
                                                                           FontWeight="Bold"
                                                                           Foreground="{Binding AccentBrush}" />
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Grid.Column="1"
                                                        Style="{StaticResource StatusPill}"
                                                        Background="{Binding StatusBackgroundBrush}"
                                                        BorderBrush="{Binding StatusBorderBrush}"
                                                        VerticalAlignment="Top"
                                                        Margin="14,0,0,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="6" Height="6" Fill="{Binding StatusBrush}" VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   FontSize="10.5"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   Margin="6,0,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#929CB1"
                                                       FontSize="11.5"
                                                       LineHeight="18"
                                                       Margin="0,13,0,0" />

                                            <Border Grid.Row="2"
                                                    Margin="0,15,0,17"
                                                    CornerRadius="13"
                                                    Background="#A60E121C"
                                                    BorderBrush="#232B3C"
                                                    BorderThickness="1"
                                                    Padding="14,11"
                                                    VerticalAlignment="Top">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="1" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Margin="0,0,14,0">
                                                        <TextBlock Text="{Binding PrimaryLabel}" Style="{StaticResource MetricCaption}" />
                                                        <TextBlock Text="{Binding PrimaryValue}"
                                                                   ToolTip="{Binding PrimaryValue}"
                                                                   Style="{StaticResource MetricValue}" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Background="#242C3E" />
                                                    <StackPanel Grid.Column="2" Margin="14,0,0,0">
                                                        <TextBlock Text="{Binding SecondaryLabel}" Style="{StaticResource MetricCaption}" />
                                                        <TextBlock Text="{Binding SecondaryValue}"
                                                                   ToolTip="{Binding SecondaryValue}"
                                                                   Style="{StaticResource MetricValue}" />
                                                    </StackPanel>

                                                    <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Background="#212839" Margin="0,10" />

                                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3">
                                                        <TextBlock Text="{Binding TertiaryLabel}" Style="{StaticResource MetricCaption}" />
                                                        <TextBlock Text="{Binding TertiaryValue}"
                                                                   ToolTip="{Binding TertiaryValue}"
                                                                   Style="{StaticResource MetricValue}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Grid Grid.Row="3" VerticalAlignment="Bottom">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Button Style="{StaticResource PrimaryButton}"
                                                        Height="44"
                                                        Click="ProfileLaunchButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding ActionText}"
                                                                   Foreground="#0C0D13"
                                                                   FontWeight="Bold" />
                                                        <TextBlock Text="↗"
                                                                   Foreground="#0C0D13"
                                                                   FontSize="15"
                                                                   Margin="13,0,0,0"
                                                                   Visibility="{Binding CanLaunch, Converter={StaticResource BoolToVisibility}}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Width="44"
                                                        Height="44"
                                                        Padding="0"
                                                        Margin="10,0,0,0"
                                                        Content="⚙"
                                                        FontSize="15"
                                                        ToolTip="打开该空间的配置中心"
                                                        Tag="{Binding ProfileId}"
                                                        Visibility="{Binding SettingsVisibility}"
                                                        Click="ProfileSettingsButton_Click" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            Margin="0,20,0,0"
                            Padding="18,14"
                            CornerRadius="17"
                            Background="#A510141E"
                            BorderBrush="#282F40"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <CheckBox x:Name="ParallelToggle"
                                      Style="{StaticResource SwitchStyle}"
                                      IsChecked="False"
                                      Checked="ParallelToggle_Changed"
                                      Unchecked="ParallelToggle_Changed" />
                            <StackPanel Grid.Column="1" Margin="13,0,24,0" VerticalAlignment="Center">
                                <TextBlock Text="允许并行启动"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#CFD4E0" />
                                <TextBlock x:Name="ParallelSummaryText"
                                           Text="默认关闭 · 不同实例不会被自动关闭或互相复用"
                                           FontSize="10.5"
                                           Foreground="#707B91"
                                           Margin="0,3,0,0" />
                            </StackPanel>

                            <Border Grid.Column="2" Width="1" Height="30" Background="#2B3244" Margin="0,0,16,0" />
                            <Button Grid.Column="3"
                                    x:Name="NewProfileButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="新建隔离空间"
                                    Margin="0,0,10,0"
                                    Click="NewProfileButton_Click" />
                            <Button Grid.Column="4"
                                    x:Name="RefreshButton"
                                    Style="{StaticResource SecondaryButton}"
                                    Content="刷新状态"
                                    Click="RefreshButton_Click" />
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="ToastHost"
                        Grid.Row="1"
                        Panel.ZIndex="40"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,24"
                        Padding="16,11"
                        CornerRadius="14"
                        Background="#F21B2130"
                        BorderBrush="#3C465E"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="5" Opacity="0.42" />
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ToastDot" Width="7" Height="7" Fill="#68DEB1" VerticalAlignment="Center" />
                        <TextBlock x:Name="ToastText"
                                   Text="状态已刷新"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#E3E7F0"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                </Border>

                <Grid x:Name="DialogOverlay"
                      Grid.RowSpan="2"
                      Panel.ZIndex="60"
                      Visibility="Collapsed"
                      Background="#C7080A10">
                    <Border Width="440"
                            Padding="28"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="#F51A1F2B"
                            BorderBrush="#474F65"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="35" ShadowDepth="10" Opacity="0.58" />
                        </Border.Effect>
                        <StackPanel>
                            <Border Width="44" Height="44" CornerRadius="14" Background="#2B2540" HorizontalAlignment="Left">
                                <TextBlock Text="Ⅱ"
                                           Foreground="#C8BEFF"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock x:Name="DialogTitleText"
                                       Text="另一实例正在运行"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Margin="0,18,0,0" />
                            <TextBlock x:Name="DialogBodyText"
                                       Text="安全模式不会自动关闭任何 Codex 窗口。"
                                       Foreground="#949EB2"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       LineHeight="19"
                                       Margin="0,10,0,0" />
                            <Border CornerRadius="13" Background="#121722" BorderBrush="#2C3447" BorderThickness="1" Padding="13,10" Margin="0,18,0,0">
                                <TextBlock Text="并行时账号与本地状态隔离，但工作目录、Chrome 和 Unity 等外部资源仍然共享。"
                                           Foreground="#B4BBC9"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           LineHeight="17" />
                            </Border>
                            <Grid Margin="0,24,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Style="{StaticResource SecondaryButton}"
                                        Content="保持安全模式"
                                        Click="DialogCancelButton_Click" />
                                <Button Grid.Column="2"
                                        Style="{StaticResource PrimaryButton}"
                                        Height="42"
                                        Content="并行并启动"
                                        Click="DialogConfirmButton_Click" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
